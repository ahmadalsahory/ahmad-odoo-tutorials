<odoo>
    <!-- 1. وراثة شاشة الفاتورة لإضافة الزر الذكي -->
    <record id="view_move_form_inherit_prev_invoices" model="ir.ui.view">
        <field name="name">account.move.form.inherit.prev.invoices</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_prev_invoices" type="object" class="oe_stat_button" icon="fa-history" invisible="move_type not in ('out_invoice', 'out_refund')">
                    <field name="prev_invoice_line_count" widget="statinfo" string="Prev-Invoices"/>
                </button>
            </xpath>
        </field>
    </record>

    <!-- 2. جدول مبسط مخصص لعرض أسطر الفواتير السابقة -->
    <record id="view_move_line_prev_invoices_tree" model="ir.ui.view">
        <field name="name">account.move.line.prev.invoices.list</field>
        <field name="model">account.move.line</field>
        <field name="arch" type="xml">
            <list create="false" edit="false" delete="false" default_order="date desc">
                <field name="product_id"/>
                <field name="name" string="Description"/>
                <field name="price_unit" widget="monetary"/>
                <field name="price_subtotal" string="Total Amount" widget="monetary"/>
                <field name="date" string="Date"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- 3. نافذة بحث وفلترة مخصصة للتجميع حسب المنتج -->
    <record id="view_move_line_prev_invoices_search" model="ir.ui.view">
        <field name="name">account.move.line.prev.invoices.search</field>
        <field name="model">account.move.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="product_id"/>
                <field name="move_id"/>
                <group expand="0" string="Group By">
                    <filter string="Product" name="group_by_product" context="{'group_by': 'product_id'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
