<odoo>
    <!-- 1. تعريف أكشن التقرير في قائمة الطباعة -->
    <record id="action_report_outstanding_lines" model="ir.actions.report">
        <field name="name">Outstanding Lines Report</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">account_prev_invoices.report_outstanding_lines_template</field>
        <field name="report_file">account_prev_invoices.report_outstanding_lines_template</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

    <!-- 2. تصميم قالب تقرير الطباعة -->
    <template id="report_outstanding_lines_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- العنوان العام للتقرير -->
                        <h2 class="text-center mt-4">Outstanding Invoices &amp; Lines Report</h2>

                        <!-- معلومات العميل وتاريخ التقرير -->
                        <div class="row mt-4 mb-4" style="border-bottom: 2px solid #ddd; padding-bottom: 10px;">
                            <div class="col-6">
                                <strong>Customer: </strong>
                                <span t-field="o.partner_id.name"/>
                            </div>
                            <div class="col-6 text-end">
                                <strong>Report Date: </strong>
                                <span t-esc="datetime.date.today().strftime('%Y-%m-%d')"/>
                            </div>
                        </div>

                        <!-- جدول الفواتير المستحقة -->
                        <table class="table table-sm mt-3" style="width: 100%; border-collapse: collapse;">
                            <thead>
                                <tr style="background-color: #7C7BAD; color: white;">
                                    <th style="padding: 8px;">Date</th>
                                    <th style="padding: 8px;">Invoice #</th>
                                    <th style="padding: 8px;" class="text-end">Residual Amount</th>
                                    <th style="padding: 8px;">Due Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.get_outstanding_invoices()" t-as="inv">
                                    <!-- سطر رأس الفاتورة المستحقة -->
                                    <tr style="background-color: #eaeaea; font-weight: bold; border-top: 1px solid #ccc;">
                                        <td style="padding: 8px;">
                                            <span t-field="inv.invoice_date" t-options="{'widget': 'date'}"/>
                                        </td>
                                        <td style="padding: 8px;">
                                            <span t-field="inv.name"/>
                                        </td>
                                        <td style="padding: 8px;" class="text-end">
                                            <span t-field="inv.amount_residual" t-options="{'widget': 'monetary', 'display_currency': inv.currency_id}"/>
                                        </td>
                                        <td style="padding: 8px;">
                                            <span t-field="inv.invoice_date_due" t-options="{'widget': 'date'}"/>
                                        </td>
                                    </tr>

                                    <!-- سطر يحتوي على الجدول الداخلي لمنتجات الفاتورة -->
                                    <tr>
                                        <td colspan="4" style="padding: 0 0 15px 30px; border: none;">
                                            <table class="table table-sm table-borderless" style="margin: 0; width: 100%; font-size: 0.9em; color: #555;">
                                                <thead>
                                                    <tr style="border-bottom: 1px solid #ddd;">
                                                        <th>Product</th>
                                                        <th>Description</th>
                                                        <th class="text-end">Quantity</th>
                                                        <th class="text-end">Unit Price</th>
                                                        <th class="text-end">Subtotal</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <t t-foreach="inv.invoice_line_ids.filtered(lambda l: l.display_type == 'product')" t-as="line">
                                                        <tr style="border-bottom: 1px dashed #eee;">
                                                            <td style="padding: 5px;">
                                                                <span t-field="line.product_id.name"/>
                                                            </td>
                                                            <td style="padding: 5px;">
                                                                <span t-field="line.name"/>
                                                            </td>
                                                            <td style="padding: 5px;" class="text-end">
                                                                <span t-field="line.quantity"/>
                                                            </td>
                                                            <td style="padding: 5px;" class="text-end">
                                                                <span t-field="line.price_unit" t-options="{'widget': 'monetary', 'display_currency': inv.currency_id}"/>
                                                            </td>
                                                            <td style="padding: 5px;" class="text-end">
                                                                <span t-field="line.price_subtotal" t-options="{'widget': 'monetary', 'display_currency': inv.currency_id}"/>
                                                            </td>
                                                        </tr>
                                                    </t>
                                                </tbody>
                                            </table>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
