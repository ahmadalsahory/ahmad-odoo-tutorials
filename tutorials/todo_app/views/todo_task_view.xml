<odoo>
    <!-- Window Action -->
    <record id="todo_task_action" model="ir.actions.act_window">
        <field name="name">Tasks</field>
        <field name="res_model">todo.task</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <!-- List View -->
    <record id="todo_task_view_list" model="ir.ui.view">
        <field name="name">todo.task.list</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <list string="To-Do Tasks">
                <field name="name"/>
                <field name="user_ids" widget="many2many_tags"/>
                <field name="date_deadline"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="todo_task_view_form" model="ir.ui.view">
        <field name="name">todo.task.form</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <form string="To-Do Task">
                <header>
                    <field name="state" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Task Title..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="date_deadline"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Timesheets">
                            <field name="timesheet_ids">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="description"/>
                                    <field name="hours" sum="Total Hours"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- Search View with custom Filters and Group By -->
    <record id="todo_task_view_search" model="ir.ui.view">
        <field name="name">todo.task.search</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <search string="Search Tasks">
                <!-- Searchable text fields -->
                <field name="name" string="Task Name"/>
                <field name="description"/>

                <!-- Filters (Filtering by Status) -->
                <filter string="New" name="status_new" domain="[('state', '=', 'new')]"/>
                <filter string="In Progress" name="status_in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Completed" name="status_completed" domain="[('state', '=', 'completed')]"/>

                <separator/>

                <!-- Group By Filters -->
                <group>
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Due Date" name="group_by_deadline" context="{'group_by': 'date_deadline'}"/>
                </group>

                <searchpanel>
                    <field name="user_ids" icon="fa-users" select="multi" enable_counters="1"/>
                </searchpanel>

            </search>
        </field>
    </record>

    <record id="todo_task_view_kanban" model="ir.ui.view">
        <field name="name">todo.task.kanban</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_title">
                                    <strong>
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="date_deadline"/>
                                </div>
                                <div class="oe_kanban_footer">
                                    <field name="user_ids" widget="many2many_tags"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

</odoo>
