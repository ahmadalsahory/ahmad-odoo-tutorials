<odoo>
    <!-- Report Action -->
    <record id="action_todo_task_report" model="ir.actions.report">
        <field name="name">Todo Task Report</field>
        <field name="model">todo.task</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">todo_app.todo_task_report_template</field>
        <field name="report_file">todo_app.todo_task_report_template</field>
        <field name="print_report_name">'Todo Task - %s' % (object.name)</field>
        <field name="binding_model_id" ref="todo_app.model_todo_task"/>
        <field name="binding_type">report</field>
    </record>

    <!-- QWeb Template -->
    <template id="todo_task_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Custom Styles for Report -->
                        <style>
                            .todo-report-header {
                                border-bottom: 2px solid #7C7BAD;
                                margin-bottom: 20px;
                                padding-bottom: 10px;
                            }
                            .todo-report-title {
                                color: #7C7BAD;
                                font-weight: bold;
                            }
                            .todo-report-table th {
                                background-color: #7C7BAD;
                                color: white;
                                font-weight: 600;
                                text-transform: uppercase;
                                font-size: 0.85em;
                                padding: 8px !important;
                                vertical-align: middle;
                            }
                            .todo-report-table td {
                                padding: 8px !important;
                                vertical-align: middle;
                            }
                            .todo-info-label {
                                font-weight: bold;
                                color: #555;
                                width: 25%;
                                background-color: #f8f9fa;
                            }
                            .todo-info-value {
                                width: 25%;
                            }
                        </style>

                        <!-- Report Header -->
                        <div class="todo-report-header row align-items-center mt-4">
                            <div class="col-8">
                                <h2 class="todo-report-title">Task Details: <span t-field="o.name"/>
                                </h2>
                            </div>
                            <div class="col-4 text-end text-muted">
                                <strong>Print Date:</strong>
                                <span t-esc="datetime.date.today().strftime('%Y-%m-%d')"/>
                            </div>
                        </div>

                        <!-- Basic Information -->
                        <h4 class="mt-4" style="color: #7C7BAD;">Task Information</h4>
                        <table class="table table-sm table-bordered mt-2">
                            <tbody>
                                <tr>
                                    <td class="todo-info-label">Title</td>
                                    <td class="todo-info-value">
                                        <span t-field="o.name"/>
                                    </td>
                                    <td class="todo-info-label">Status</td>
                                    <td class="todo-info-value">
                                        <t t-if="o.state == 'new'">
                                            <span class="badge bg-primary px-2 py-1 text-white">New</span>
                                        </t>
                                        <t t-elif="o.state == 'in_progress'">
                                            <span class="badge bg-warning px-2 py-1 text-dark">In Progress</span>
                                        </t>
                                        <t t-elif="o.state == 'completed'">
                                            <span class="badge bg-success px-2 py-1 text-white">Completed</span>
                                        </t>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="todo-info-label">Due Date</td>
                                    <td class="todo-info-value">
                                        <span t-field="o.date_deadline" t-options="{'widget': 'date'}"/>
                                    </td>
                                    <td class="todo-info-label">Assigned Users</td>
                                    <td class="todo-info-value">
                                        <t t-foreach="o.user_ids" t-as="user">
                                            <span t-field="user.name"/>
                                            <t t-if="not user_last">, </t>
                                        </t>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Description Block -->
                        <h4 class="mt-4" style="color: #7C7BAD;">Description</h4>
                        <div class="card bg-light mt-2 mb-4">
                            <div class="card-body py-2 px-3">
                                <t t-if="o.description">
                                    <span t-field="o.description"/>
                                </t>
                                <t t-else="">
                                    <span class="text-muted fst-italic">No description provided.</span>
                                </t>
                            </div>
                        </div>

                        <!-- Timesheets list table -->
                        <h4 class="mt-4" style="color: #7C7BAD;">Timesheets</h4>
                        <t t-if="o.timesheet_ids">
                            <table class="table table-sm table-bordered todo-report-table mt-2">
                                <thead>
                                    <tr>
                                        <th style="width: 20%;">Date</th>
                                        <th>Description</th>
                                        <th class="text-end" style="width: 20%;">Time (Hours)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.timesheet_ids" t-as="line">
                                        <tr>
                                            <td>
                                                <span t-field="line.date" t-options="{'widget': 'date'}"/>
                                            </td>
                                            <td>
                                                <span t-field="line.description"/>
                                            </td>
                                            <td class="text-end">
                                                <span t-field="line.hours" t-options="{'widget': 'float', 'precision': 2}"/>
                                            </td>
                                        </tr>
                                    </t>
                                    <!-- Total Sum row -->
                                    <tr class="fw-bold" style="background-color: #f8f9fa;">
                                        <td colspan="2" class="text-start">Total Hours</td>
                                        <td class="text-end text-primary">
                                            <span t-esc="sum(o.timesheet_ids.mapped('hours'))" t-options="{'widget': 'float', 'precision': 2}"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </t>
                        <t t-else="">
                            <p class="text-muted mt-2">No timesheet hours logged for this task.</p>
                        </t>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
