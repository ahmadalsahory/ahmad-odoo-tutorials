<odoo>
    <!-- 1. Report action (binds this report to the Print menu on the property list/form) -->
    <record id="property_report" model="ir.actions.report">
        <field name="name">Property Report</field>
        <field name="model">estate.property</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">estate.property_report_template</field>
        <field name="report_file">estate.property_report_template</field>
        <field name="print_report_name">'Property - %s' % (object.name)</field>
        <field name="binding_model_id" ref="estate.model_estate_property"/>
        <field name="binding_type">report</field>
    </record>

    <!-- 2. QWeb PDF template -->
    <template id="property_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">

                        <!-- Report title -->
                        <h2 class="text-center mt-4">Property Details Report</h2>
                        <hr/>

                        <!-- Scoped report styles -->
                        <style>
                            .page table th {
                                background-color: #2c3e50;
                                color: #ffffff;
                                font-weight: 600;
                                font-size: 0.78em;
                                text-transform: uppercase;
                                letter-spacing: 0.05em;
                                padding: 7px 10px !important;
                                vertical-align: middle;
                            }
                            .page table td {
                                padding: 7px 10px;
                                vertical-align: middle;
                                color: #333;
                            }
                            .page table {
                                border-color: #dee2e6;
                            }
                        </style>

                        <!-- ── Basic Information ── -->
                        <h4 class="mt-4">Basic Information</h4>
                        <table class="table table-sm table-bordered">
                            <tbody>
                                <tr>
                                    <th style="width:30%">Title</th>
                                    <td>
                                        <span t-field="o.name"/>
                                    </td>
                                    <th style="width:20%">Status</th>
                                    <td>
                                        <span t-field="o.state"/>
                                    </td>
                                </tr>
                                <tr>
                                    <th>Property Type</th>
                                    <td>
                                        <span t-field="o.property_type_id.name"/>
                                    </td>
                                    <th>Postcode</th>
                                    <td>
                                        <span t-field="o.postcode"/>
                                    </td>
                                </tr>
                                <tr>
                                    <th>Availability Date</th>
                                    <td>
                                        <span t-field="o.date_availability" t-options="{'widget': 'date'}"/>
                                    </td>
                                    <th>Tags</th>
                                    <td>
                                        <t t-foreach="o.tag_ids" t-as="tag">
                                            <span t-field="tag.name"/>
                                            <t t-if="not tag_last">, </t>
                                        </t>
                                    </td>
                                </tr>
                                <tr>
                                    <th>Description</th>
                                    <td colspan="3">
                                        <span t-field="o.description"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- ── Pricing ── -->
                        <h4 class="mt-4">Pricing</h4>
                        <table class="table table-sm table-bordered">
                            <tbody>
                                <tr>
                                    <th style="width:30%">Expected Price</th>
                                    <td>
                                        <span t-field="o.expected_price"/>
                                    </td>
                                    <th style="width:20%">Selling Price</th>
                                    <td>
                                        <span t-field="o.selling_price"/>
                                    </td>
                                </tr>
                                <tr>
                                    <th>Best Offer Price</th>
                                    <td colspan="3">
                                        <span t-field="o.best_price"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- ── Property Features ── -->
                        <h4 class="mt-4">Property Features</h4>
                        <table class="table table-sm table-bordered">
                            <tbody>
                                <tr>
                                    <th style="width:30%">Bedrooms</th>
                                    <td>
                                        <span t-field="o.bedrooms"/>
                                    </td>
                                    <th style="width:20%">Living Area (sqm)</th>
                                    <td>
                                        <span t-field="o.living_area"/>
                                    </td>
                                </tr>
                                <tr>
                                    <th>Facades</th>
                                    <td>
                                        <span t-field="o.facades"/>
                                    </td>
                                    <th>Garage</th>
                                    <td>
                                        <span t-field="o.garage"/>
                                    </td>
                                </tr>
                                <tr>
                                    <th>Garden</th>
                                    <td>
                                        <span t-field="o.garden"/>
                                    </td>
                                    <th>Garden Area (sqm)</th>
                                    <td>
                                        <span t-field="o.garden_area"/>
                                    </td>
                                </tr>
                                <tr>
                                    <th>Garden Orientation</th>
                                    <td colspan="3">
                                        <span t-field="o.garden_orientation"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- ── People ── -->
                        <h4 class="mt-4">People</h4>
                        <table class="table table-sm table-bordered">
                            <tbody>
                                <tr>
                                    <th style="width:30%">Owner</th>
                                    <td>
                                        <span t-field="o.owner_id.name"/>
                                    </td>
                                    <th style="width:20%">Owner Phone</th>
                                    <td>
                                        <span t-field="o.owner_phone"/>
                                    </td>
                                </tr>
                                <tr>
                                    <th>Salesperson</th>
                                    <td>
                                        <span t-field="o.salesperson_id.name"/>
                                    </td>
                                    <th>Buyer</th>
                                    <td>
                                        <span t-field="o.buyer_id.name"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- ── Offers ── -->
                        <h4 class="mt-4">Offers</h4>
                        <t t-if="o.offer_ids">
                            <table class="table table-sm table-bordered">
                                <thead>
                                    <tr style="background-color:#4a90d9; color:white;">
                                        <th>Partner</th>
                                        <th class="text-end">Price</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.offer_ids" t-as="offer">
                                        <tr>
                                            <td>
                                                <span t-field="offer.partner_id.name"/>
                                            </td>
                                            <td class="text-end">
                                                <span t-field="offer.price"/>
                                            </td>
                                            <td>
                                                <span t-field="offer.status"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                        <t t-else="">
                            <p class="text-muted">No offers received yet.</p>
                        </t>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
