<odoo>
    <record id="action_estate_owner_tag" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">estate.owner.tag</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="estate_owner_tag_view_list" model="ir.ui.view">
        <field name="name">estate.owner.tag.list</field>
        <field name="model">estate.owner.tag</field>
        <field name="arch" type="xml">
            <list string="Tags">
                <field name="name"/>
                <field name="owner_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <record id="estate_owner_tag_view_form" model="ir.ui.view">
        <field name="name">estate.owner.tag.form</field>
        <field name="model">estate.owner.tag</field>
        <field name="arch" type="xml">
            <form string="Tag">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                    <notebook>
                        <page string="Owners">
                            <field name="owner_ids" readonly="1">
                                <list string="Owners">
                                    <field name="name"/>
                                    <field name="phone"/>
                                    <field name="address"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem id="owner_tag_menu" name="Tags" parent="manage_menu" action="action_estate_owner_tag"/>
</odoo>
