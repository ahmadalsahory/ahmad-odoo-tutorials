<odoo>
    <record id="property_action" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">estate.property</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="estate_property_view_list" model="ir.ui.view">
        <field name="name">estate property list</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <list string="Properties">
                <field name="name" optional="show"/>
                <field name="description" optional="hidden"/>
                <field name="postcode" optional="hidden"/>
                <field name="date_availability" optional="show"/>
                <field name="expected_price" optional="show"/>
                <field name="selling_price" optional="show"/>
                <field name="bedrooms" optional="show"/>
                <field name="living_area" optional="show"/>
                <field name="facades" optional="show"/>
                <field name="garage" optional="show"/>
                <field name="garden" optional="show"/>
                <field name="garden_area" optional="show"/>
                <field name="garden_orientation" optional="hidden"/>
                <field name="active" optional="hidden"/>
                <field name="state" optional="hidden"/>
                <field name="owner_id" optional="hidden"/>
            </list>
        </field>
    </record>

    <record id="estate_property_view_form" model="ir.ui.view">
        <field name="name">Property Form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <form string="Property">
                <sheet>
                    <header>
                        <field name="state" widget="statusbar" options="{'clickable':1}"/>
                    </header>
                    <group>
                        <group string="Main Info">
                            <field name="name"/>
                            <field name="bedrooms"/>
                            <field name="living_area"/>
                            <field name="facades"/>
                            <field name="expected_price"/>
                            <!-- <field name="state"/> -->
                            <field name="active"/>
                        </group>
                        <group string="Other Info">
                            <field name="owner_id" />
                            <field name="postcode"/>
                            <field name="date_availability"/>
                            <field name="selling_price"/>
                            <field name="garage"/>
                            <field name="garden"/>
                            <field name="garden_area"/>
                            <field name="garden_orientation"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="property_view_search" model="ir.ui.view">
        <field name="name">Search</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <search string="Search Properties">
                <field name="name" string="Title"/>
                <field name="postcode"/>

                <filter name="filter_available" string="Available Properties" domain="[('state', 'in', ('new', 'offer-received'))]"/>

                <group>
                    <filter name="group_by_postcode" string="Postcode" context="{'group_by': 'postcode'}"/>
                </group>
            </search>
        </field>
    </record>


    <menuitem id="property_menu" name="Properties" parent="manage_menu" action="property_action" />
</odoo>