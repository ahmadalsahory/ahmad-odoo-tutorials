<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- وراثة واجهة res.company.form -->
    <record id="view_company_form_inherit_retail_price" model="ir.ui.view">
        <field name="name">res.company.form.inherit.retail.price</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <!-- استهدف حقل currency_id لوضع حقلنا بعده -->
            <xpath expr="//field[@name='currency_id']" position="after">
                <field name="retail_pricelist_id"/>
            </xpath>
        </field>
    </record>
</odoo>
