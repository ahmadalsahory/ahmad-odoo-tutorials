<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 1. تبسيط وراثة صندوق الدفع واستدعاء قالب السعر مباشرة -->
    <template id="cta_wrapper_boxed_inherit_retail" inherit_id="website_sale.cta_wrapper_boxed">
        <xpath expr="//span[@name='o_wsale_cta_wrapper_boxed_price_label']/.." position="replace">
            <t t-call="website_sale.product_price"/>
        </xpath>
    </template>

    <!-- 2. وراثة وتخصيص قالب السعر ليحتوي على الهيكل الكامل والصفوف متناسقة ومتحركة -->
    <template id="product_price_inherit_retail" inherit_id="website_sale.product_price">
        <!-- تعديل الحاوية الأب لتكون flex column تحتل كامل العرض فقط في صفحة المنتج -->
        <xpath expr="//div[@name='product_price']" position="attributes">
            <attribute name="t-attf-class" remove="d-inline-block" add="{{'d-flex flex-column gap-2 w-100 mb-3 pb-3 border-bottom' if (main_object and main_object._name == 'product.template') else 'd-inline-block'}}" separator=" "/>
        </xpath>

        <!-- تعديل صف السعر الأساسي ووضع التسمية Price بجانبه في صفحة المنتج -->
        <xpath expr="//div[@name='product_price_container']" position="replace">
            <t t-if="main_object and main_object._name == 'product.template'">
                <div class="d-flex justify-content-between align-items-center w-100">
                    <span class="text-muted">Price</span>
                    <div name="product_price_container" class="css_editable_mode_hidden d-flex align-items-baseline gap-2 flex-wrap h5 mb-0 text-wrap">
                        <span class="oe_price" style="white-space: nowrap;" t-out="combination_info['price']" t-options="{'widget': 'monetary', 'display_currency': website.currency_id}"/>
                        <span t-attf-class="text-muted oe_default_price mb-0 h6 {{'' if combination_info['has_discounted_price'] else 'd-none'}}" style="text-decoration: line-through; white-space: nowrap;" t-out="combination_info['list_price']" t-options="{'widget': 'monetary', 'display_currency': website.currency_id}" name="product_list_price"/>
                        <t t-if="is_view_active('website_sale.tax_indication')" t-call="website_sale.tax_indication"/>
                        <del name="product_price_strikethrough" t-if="combination_info.get('compare_list_price') and (combination_info['compare_list_price'] &gt; combination_info['price'])" class="text-muted ms-1 h6 oe_compare_list_price">
                            <bdi dir="inherit">
                            <span t-out="combination_info['compare_list_price']" t-options="{'widget': 'monetary', 'display_currency': website.currency_id}"/>
                            </bdi>
                        </del>
                    </div>
                </div>
            </t>
            <t t-else="">
                <div name="product_price_container" class="css_editable_mode_hidden d-flex align-items-baseline justify-content-end gap-2 flex-wrap h5 mb-0 text-wrap">
                    <span class="oe_price" style="white-space: nowrap;" t-out="combination_info['price']" t-options="{'widget': 'monetary', 'display_currency': website.currency_id}"/>
                    <span t-attf-class="text-muted oe_default_price mb-0 h6 {{'' if combination_info['has_discounted_price'] else 'd-none'}}" style="text-decoration: line-through; white-space: nowrap;" t-out="combination_info['list_price']" t-options="{'widget': 'monetary', 'display_currency': website.currency_id}" name="product_list_price"/>
                    <t t-if="is_view_active('website_sale.tax_indication')" t-call="website_sale.tax_indication"/>
                    <del name="product_price_strikethrough" t-if="combination_info.get('compare_list_price') and (combination_info['compare_list_price'] &gt; combination_info['price'])" class="text-muted ms-1 h6 oe_compare_list_price">
                        <bdi dir="inherit">
                        <span t-out="combination_info['compare_list_price']" t-options="{'widget': 'monetary', 'display_currency': website.currency_id}"/>
                        </bdi>
                    </del>
                </div>
            </t>
        </xpath>

        <!-- حقن صف سعر التجزئة Retail Price في صفحة المنتج فقط -->
        <xpath expr="//div[@name='product_price']" position="inside">
            <t t-if="main_object and main_object._name == 'product.template'">
                <div t-if="combination_info.get('retail_price')" class="d-flex justify-content-between align-items-center w-100">
                    <span class="text-muted">Retail Price</span>
                    <span class="oe_retail_price h6 mb-0 text-muted" t-out="combination_info['retail_price']" t-options="{'widget': 'monetary', 'display_currency': website.currency_id}"/>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
