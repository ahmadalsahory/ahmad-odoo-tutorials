<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.custom.dropship</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='product_packs_tracking']" position="after">
                <setting id="custom_dropship_setting" string="Custom Drop-ship" help="Consolidate dropship purchase orders under a custom Sales Order supplier">
                    <field name="custom_dropship"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
