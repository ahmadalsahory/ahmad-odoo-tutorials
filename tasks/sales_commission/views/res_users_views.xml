<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- View inheritance for Main Users Form (Settings -> Users) -->
    <record id="view_users_form_sales_commission" model="ir.ui.view">
        <field name="name">res.users.form.sales.commission</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Commission" name="commission_plan">
                    <group>
                        <group string="Sales Commission Configuration">
                            <field name="commission_plan_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- View inheritance for Simple Users Form (Sales -> Salespersons) -->
    <record id="view_users_simple_form_sales_commission" model="ir.ui.view">
        <field name="name">res.users.simple.form.sales.commission</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_simple_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Sales Commission Configuration">
                    <field name="commission_plan_id" options="{'no_create': True}"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- View inheritance for User Preferences Form -->
    <record id="view_users_form_simple_sales_commission" model="ir.ui.view">
        <field name="name">res.users.form.simple.sales.commission</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form_simple_modif"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Sales Commission Configuration">
                    <field name="commission_plan_id" options="{'no_create': True}"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
