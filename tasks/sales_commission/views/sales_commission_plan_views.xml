<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View for Commission Plan -->
    <record id="view_sales_commission_plan_form" model="ir.ui.view">
        <field name="name">sales.commission.plan.form</field>
        <field name="model">sales.commission.plan</field>
        <field name="arch" type="xml">
            <form string="Sales Commission Plan">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Senior Sales Representative Plan"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="active" invisible="1"/>
                            <field name="user_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Commission Ranges">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="amount_from"/>
                                    <field name="amount_to"/>
                                    <field name="rate"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View for Commission Plan -->
    <record id="view_sales_commission_plan_tree" model="ir.ui.view">
        <field name="name">sales.commission.plan.list</field>
        <field name="model">sales.commission.plan</field>
        <field name="arch" type="xml">
            <list string="Sales Commission Plans">
                <field name="name"/>
                <field name="user_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <!-- Action for Commission Plan -->
    <record id="action_sales_commission_plan" model="ir.actions.act_window">
        <field name="name">Commission Plans</field>
        <field name="res_model">sales.commission.plan</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Sales Commission Plan!
            </p>
            <p>
                Define range percentage rules for salespersons.
            </p>
        </field>
    </record>
</odoo>
