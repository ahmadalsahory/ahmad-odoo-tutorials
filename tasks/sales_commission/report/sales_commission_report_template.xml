<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_sales_commission" model="ir.actions.report">
        <field name="name">Sales Commission Report</field>
        <field name="model">sales.commission.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sales_commission.report_sales_commission_document</field>
        <field name="report_file">sales_commission.report_sales_commission_document</field>
        <field name="print_report_name">'Sales Commission Report - %s' % (object.date_to)</field>
        <field name="binding_model_id" ref="model_sales_commission_report_wizard"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_sales_commission_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center">Sales Commission Report</h2>
                        <div class="row mt-4 mb-4">
                            <div class="col-6">
                                <strong>Start Date:</strong> <span t-field="doc.date_from"/>
                            </div>
                            <div class="col-6 text-end">
                                <strong>End Date:</strong> <span t-field="doc.date_to"/>
                            </div>
                        </div>

                        <table class="table table-sm table-striped mt-3">
                            <thead>
                                <tr>
                                    <th>Salesperson</th>
                                    <th>Commission Plan</th>
                                    <th class="text-end">Paid Invoices Amount</th>
                                    <th class="text-end">Paid Credit Notes Amount</th>
                                    <th class="text-end">Net Sales Amount</th>
                                    <th class="text-end">Commission Rate (%)</th>
                                    <th class="text-end">Commission Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.line_ids" t-as="line">
                                    <tr>
                                        <td><span t-field="line.user_id.name"/></td>
                                        <td><span t-field="line.plan_id.name"/></td>
                                        <td class="text-end"><span t-field="line.invoiced_amount"/></td>
                                        <td class="text-end"><span t-field="line.refund_amount"/></td>
                                        <td class="text-end"><span t-field="line.net_amount"/></td>
                                        <td class="text-end"><span t-field="line.rate"/>%</td>
                                        <td class="text-end"><strong><span t-field="line.commission_amount"/></strong></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
